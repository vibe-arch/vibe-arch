{
  "name": "vibe-arch",
  "version": "0.1.2",
  "description": "AI-friendly architecture context manager for vibe coding. Automatically manages CLAUDE.md and enforces architecture rules.",
  "main": "./dist/index.js",
  "bin": {
    "vibe-arch": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "types"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vibe-arch/vibe-arch"
  },
  "keywords": [
    "ai",
    "vibe-coding",
    "architecture",
    "claude",
    "gpt",
    "context-manager",
    "cli",
    "ai-driven",
    "metadata",
    "architecture-management"
  ],
  "author": "vibe-arch contributors",
  "bugs": {
    "url": "https://github.com/vibe-arch/vibe-arch/issues"
  },
  "homepage": "https://github.com/vibe-arch/vibe-arch#readme",
  "license": "MIT",
  "scripts": {
    "build": "tsc && node scripts/bundle.js",
    "dev": "ts-node src/index.ts",
    "prepublishOnly": "npm test && npm run build",
    "test": "npx ts-node tests/core.test.ts && npx ts-node tests/ignore.test.ts && npx ts-node tests/cli.test.ts && npx ts-node tests/daemon.test.ts && npx ts-node tests/sidecar.test.ts && npx ts-node tests/java_kotlin.test.ts"
  },
  "dependencies": {
